<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="quanan-pu">
        <class>ltw.ck.quanlyquanan.model.entity.Ban</class>
        <class>ltw.ck.quanlyquanan.model.entity.HoaDon</class>
        <class>ltw.ck.quanlyquanan.model.entity.KhachHang</class>
        <class>ltw.ck.quanlyquanan.model.entity.LoaiKH</class>
        <class>ltw.ck.quanlyquanan.model.entity.LoaiMonAn</class>
        <class>ltw.ck.quanlyquanan.model.entity.MonAn</class>
        <class>ltw.ck.quanlyquanan.model.entity.NhanVien</class>
        <class>ltw.ck.quanlyquanan.model.entity.TaiKhoan</class>
        <class>ltw.ck.quanlyquanan.model.entity.ChiTietHD</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/db_quan_an?serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="."/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.highlight_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
